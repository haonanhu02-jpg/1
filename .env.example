TZ=Asia/Shanghai

# Host ports.
WEB_HTTP_PORT=8080
BACKEND_HOST_PORT=8085
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380

# MySQL. The init scripts create MYSQL_DATABASE only on the first empty mysql_data volume.
MYSQL_DATABASE=scrm_ky
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me_mysql_root_password
SPRING_DATASOURCE_URL=jdbc:mysql://iyque-mysql:3306/scrm_ky?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai

# Redis. Leave REDIS_PASSWORD empty only for local development.
REDIS_PASSWORD=change_me_redis_password
SPRING_REDIS_DATABASE=1

# Iyque runtime.
IYQUE_ADMIN_USERNAME=iyque
IYQUE_ADMIN_PASSWORD=change_me_admin_password
IYQUE_FILE_VIEW_URL=http://localhost:8080/api/file/fileView/
IYQUE_DEMO=false
IYQUE_INQUIRY_ALL=true

# WeCom. These override the configuration stored in iyque_config when non-empty.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_MSG_AUDIT_LIB_PATH=
WECOM_MSG_AUDIT_PRIVATE_KEY=
WECOM_MSG_AUDIT_SECRET=

# Optional AI and vector settings.
AI_GLM4_API_KEY=
AI_EMBEDDING3_API_KEY=
AI_VECTOR_HOST=127.0.0.1
AI_VECTOR_PORT=19530

# Optional JVM tuning.
JAVA_OPTS=-Xms512m -Xmx1024m
